{
  "datasets": [
    {
      "name": "effort_hypothesis",
      "displayName": "Effort Hypothesis",
      "queryLines": [
        "SELECT\n",
        "  object_type AS `Object Type`,\n",
        "  complexity_level AS `Complexity`,\n",
        "  transpilability_status AS `Status`,\n",
        "  profile AS `Profile`,\n",
        "  effort_md_per_unit AS `MD / Unit`,\n",
        "  notes AS `Notes`,\n",
        "  1 AS sort_key\n",
        "FROM\n",
        "  classic_stable_pr2ip7.lakebridge_assessment.effort_hypothesis\n",
        "UNION ALL\n",
        "SELECT\n",
        "  '\u2014 Overhead' AS `Object Type`,\n",
        "  profile AS `Complexity`,\n",
        "  NULL AS `Status`,\n",
        "  profile AS `Profile`,\n",
        "  rate AS `MD / Unit`,\n",
        "  CONCAT(CAST(CAST(rate * 100 AS INT) AS STRING), '% of dev total \u2014 ', notes) AS `Notes`,\n",
        "  2 AS sort_key\n",
        "FROM\n",
        "  classic_stable_pr2ip7.lakebridge_assessment.overhead_hypothesis\n",
        "ORDER BY\n",
        "  sort_key,\n",
        "  `Object Type`,\n",
        "  `Complexity`,\n",
        "  `Status`"
      ]
    },
    {
      "name": "effort_estimate",
      "displayName": "Effort Estimate",
      "queryLines": [
        "SELECT * FROM classic_stable_pr2ip7.lakebridge_assessment.effort_metrics"
      ]
    },
    {
      "name": "migration_summary",
      "displayName": "Migration Summary",
      "queryLines": [
        "SELECT * FROM classic_stable_pr2ip7.lakebridge_assessment.assessment_metrics"
      ]
    }
  ],
