<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:ObjectName="ETL_Load_Customer_Dim">
  <DTS:Executables>
    <DTS:Executable DTS:ObjectName="Extract Customers from Source"
      DTS:ExecutableType="Microsoft.Pipeline">
      <DTS:ObjectData>
        <pipeline>
          <components>
            <component componentClassID="Microsoft.OLEDBSource" name="OLE DB Source">
              <properties>
                <property name="SqlCommand">SELECT TOP 1000 CustomerID, FirstName, LastName, ISNULL(Email, 'N/A') AS Email, CONVERT(VARCHAR, CreatedDate, 120) AS CreatedDate FROM dbo.Customer WHERE IsActive = 1 AND CreatedDate >= DATEADD(MONTH, -3, GETDATE())</property>
              </properties>
            </component>
            <component componentClassID="Microsoft.OLEDBDestination" name="Load dim_customer">
              <properties>
                <property name="OpenRowset">[dw].[dim_customer]</property>
              </properties>
            </component>
          </components>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:ObjectName="Refresh Customer Metrics"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData>
          <SqlStatement>UPDATE dbo.CustomerMetrics SET LastOrderDate = (SELECT MAX(OrderDate) FROM dbo.SalesOrderHeader o WHERE o.CustomerID = CustomerMetrics.CustomerID), TotalSpend = (SELECT ISNULL(SUM(TotalDue), 0) FROM dbo.SalesOrderHeader o WHERE o.CustomerID = CustomerMetrics.CustomerID) WHERE EXISTS (SELECT 1 FROM dbo.SalesOrderHeader o WHERE o.CustomerID = CustomerMetrics.CustomerID AND o.OrderDate &gt;= DATEADD(DAY, -1, GETDATE()))</SqlStatement>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
