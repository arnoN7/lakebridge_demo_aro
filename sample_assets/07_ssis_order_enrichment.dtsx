<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:ObjectName="ETL_Order_Enrichment"
  DTS:Description="Complex order enrichment pipeline with lookups, conditional split, derived columns, multicast, and error handling"
  DTS:CreatorName="DOMAIN\etl_admin"
  DTS:DTSID="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">

  <!-- CONNECTION MANAGERS -->
  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:ObjectName="OLTP_Source"
      DTS:DTSID="{11111111-1111-1111-1111-111111111111}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLPROD01;Initial Catalog=SalesDB;Provider=SQLNCLI11.1;Integrated Security=SSPI;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="DW_Destination"
      DTS:DTSID="{22222222-2222-2222-2222-222222222222}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLDW01;Initial Catalog=DataWarehouse;Provider=SQLNCLI11.1;Integrated Security=SSPI;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="ErrorLog_FlatFile"
      DTS:DTSID="{33333333-3333-3333-3333-333333333333}"
      DTS:CreationName="FLATFILE">
      <DTS:ObjectData>
        <DTS:ConnectionManager Format="Delimited" ColumnNamesInFirstDataRow="True"
          ConnectionString="\\fileserver\etl_logs\order_errors.csv"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <!-- VARIABLES -->
  <DTS:Variables>
    <DTS:Variable DTS:ObjectName="HighValueThreshold" DTS:DataType="4" DTS:Namespace="User">5000</DTS:Variable>
    <DTS:Variable DTS:ObjectName="BatchStartDate" DTS:DataType="7" DTS:Namespace="User"
      DTS:Expression="DATEADD(&quot;dd&quot;, -1, GETDATE())"/>
    <DTS:Variable DTS:ObjectName="RowsProcessed" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="ErrorCount" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="ProcessingMode" DTS:DataType="8" DTS:Namespace="User">INCREMENTAL</DTS:Variable>
  </DTS:Variables>

  <!-- CONTROL FLOW -->
  <DTS:Executables>

    <!-- Task 1: Truncate staging -->
    <DTS:Executable DTS:ObjectName="SQL - Truncate Staging"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="DW_Destination">
          <SqlStatement>TRUNCATE TABLE staging.stg_orders_enriched</SqlStatement>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- Task 2: Main Data Flow -->
    <DTS:Executable DTS:ObjectName="DFT - Enrich and Route Orders"
      DTS:ExecutableType="Microsoft.Pipeline">
      <DTS:ObjectData>
        <pipeline>
          <components>

            <!-- SOURCE -->
            <component componentClassID="Microsoft.OLEDBSource" name="SRC - Extract New Orders">
              <properties>
                <property name="SqlCommand">SELECT o.OrderID, o.CustomerID, o.OrderDate, o.ShipDate, o.TotalAmount, o.CurrencyCode, o.ShipToCountry, o.ShipToPostalCode, o.SalesRepID, o.ChannelCode, o.PromotionCode, DATEDIFF(DAY, o.OrderDate, ISNULL(o.ShipDate, GETDATE())) AS FulfillmentDays, CASE WHEN o.TotalAmount &gt; 5000 THEN 'HIGH' WHEN o.TotalAmount &gt; 1000 THEN 'MEDIUM' ELSE 'LOW' END AS ValueSegment FROM dbo.SalesOrder o WITH (NOLOCK) WHERE o.OrderDate &gt;= ? AND o.StatusCode IN ('NEW','MODIFIED','REOPENED') ORDER BY o.OrderDate DESC</property>
                <property name="ParameterMapping">@[$Package::BatchStartDate]:Input:0:DB_DBTIMESTAMP</property>
              </properties>
              <outputs>
                <output name="OLE DB Source Output"/>
                <output name="OLE DB Source Error Output" isErrorOut="true"/>
              </outputs>
            </component>

            <!-- LOOKUP 1: Customer dimension (full cache) -->
            <component componentClassID="Microsoft.Lookup" name="LKP - Customer Dimension">
              <properties>
                <property name="SqlCommand">SELECT CustomerID, CustomerTier, RegionName, AccountManagerID, CreditLimit, IsVIP FROM dw.dim_customer WHERE IsActive = 1</property>
                <property name="NoMatchBehavior">SendToNoMatchOutput</property>
                <property name="CacheType">Full</property>
              </properties>
              <outputs>
                <output name="Lookup Match Output"/>
                <output name="Lookup No Match Output"/>
              </outputs>
            </component>

            <!-- LOOKUP 2: Promotion validity (partial cache) -->
            <component componentClassID="Microsoft.Lookup" name="LKP - Promotion Validity">
              <properties>
                <property name="SqlCommand">SELECT PromotionCode, DiscountPct, StartDate, EndDate, CASE WHEN GETDATE() BETWEEN StartDate AND EndDate THEN 1 ELSE 0 END AS IsValid FROM dbo.Promotions</property>
                <property name="NoMatchBehavior">SendToNoMatchOutput</property>
                <property name="CacheType">Partial</property>
                <property name="MaxMemoryUsage">25</property>
              </properties>
              <outputs>
                <output name="Lookup Match Output"/>
                <output name="Lookup No Match Output"/>
              </outputs>
            </component>

            <!-- DERIVED COLUMN -->
            <component componentClassID="Microsoft.DerivedColumn" name="DER - Compute Business Rules">
              <properties>
                <property name="DerivedColumns">
                  <derivedColumn name="NetAmount" expression="TotalAmount * (1 - ISNULL(DiscountPct, 0))" dataType="DT_CY"/>
                  <derivedColumn name="IsOverCreditLimit" expression="TotalAmount &gt; CreditLimit ? TRUE : FALSE" dataType="DT_BOOL"/>
                  <derivedColumn name="FulfillmentSLA" expression="FulfillmentDays &gt; 5 ? &quot;BREACHED&quot; : &quot;OK&quot;" dataType="DT_WSTR" length="10"/>
                  <derivedColumn name="ProcessedTimestamp" expression="GETDATE()" dataType="DT_DBTIMESTAMP"/>
                  <derivedColumn name="FiscalQuarter" expression="&quot;FY&quot; + (DT_WSTR,4)YEAR(OrderDate) + &quot;-Q&quot; + (DT_WSTR,1)DATEPART(&quot;qq&quot;, OrderDate)" dataType="DT_WSTR" length="10"/>
                  <derivedColumn name="RiskScore" expression="(IsVIP == TRUE ? 0 : 10) + (IsOverCreditLimit == TRUE ? 50 : 0) + (FulfillmentDays &gt; 7 ? 20 : 0)" dataType="DT_I4"/>
                </property>
              </properties>
            </component>

            <!-- CONDITIONAL SPLIT -->
            <component componentClassID="Microsoft.ConditionalSplit" name="CSPL - Route by Segment and Risk">
              <outputs>
                <output name="High Value VIP" expression="ValueSegment == &quot;HIGH&quot; AND IsVIP == TRUE"/>
                <output name="High Value Standard" expression="ValueSegment == &quot;HIGH&quot; AND IsVIP == FALSE"/>
                <output name="Over Credit Limit" expression="IsOverCreditLimit == TRUE"/>
                <output name="SLA Breached" expression="FulfillmentSLA == &quot;BREACHED&quot;"/>
                <output name="Medium Value" expression="ValueSegment == &quot;MEDIUM&quot;"/>
                <output name="Default Output"/>
              </outputs>
            </component>

            <!-- MULTICAST -->
            <component componentClassID="Microsoft.Multicast" name="MCT - Duplicate High Value for Audit">
              <outputs>
                <output name="To Fact Table"/>
                <output name="To Audit Table"/>
              </outputs>
            </component>

            <!-- OLE DB COMMAND: Flag credit-risk orders -->
            <component componentClassID="Microsoft.OLEDBCommand" name="CMD - Flag Credit Risk">
              <properties>
                <property name="SqlCommand">EXEC dbo.usp_FlagCreditHold @OrderID = ?</property>
              </properties>
            </component>

            <!-- DESTINATIONS -->
            <component componentClassID="Microsoft.OLEDBDestination" name="DST - fact_orders_enriched">
              <properties>
                <property name="OpenRowset">[dw].[fact_orders_enriched]</property>
                <property name="FastLoadOptions">TABLOCK,CHECK_CONSTRAINTS,ROWS_PER_BATCH=10000</property>
                <property name="AccessMode">3</property>
              </properties>
            </component>

            <component componentClassID="Microsoft.OLEDBDestination" name="DST - audit_high_value_orders">
              <properties>
                <property name="OpenRowset">[audit].[high_value_orders]</property>
                <property name="FastLoadOptions">TABLOCK</property>
              </properties>
            </component>

            <component componentClassID="Microsoft.FlatFileDestination" name="DST - Error Log File">
              <properties>
                <property name="ConnectionManager">{33333333-3333-3333-3333-333333333333}</property>
                <property name="Overwrite">false</property>
              </properties>
            </component>

            <component componentClassID="Microsoft.OLEDBDestination" name="DST - SLA Breach Queue">
              <properties>
                <property name="OpenRowset">[notifications].[sla_breach_queue]</property>
              </properties>
            </component>

          </components>

          <!-- DATA FLOW PATHS -->
          <paths>
            <path startId="SRC - Extract New Orders.Output" endId="LKP - Customer Dimension.Input"/>
            <path startId="LKP - Customer Dimension.Match Output" endId="LKP - Promotion Validity.Input"/>
            <path startId="LKP - Promotion Validity.Match Output" endId="DER - Compute Business Rules.Input"/>
            <path startId="LKP - Promotion Validity.No Match Output" endId="DER - Compute Business Rules.Input"/>
            <path startId="DER - Compute Business Rules.Output" endId="CSPL - Route by Segment and Risk.Input"/>
            <path startId="CSPL - Route by Segment and Risk.High Value VIP" endId="MCT - Duplicate High Value for Audit.Input"/>
            <path startId="CSPL - Route by Segment and Risk.High Value Standard" endId="MCT - Duplicate High Value for Audit.Input"/>
            <path startId="CSPL - Route by Segment and Risk.Over Credit Limit" endId="CMD - Flag Credit Risk.Input"/>
            <path startId="CSPL - Route by Segment and Risk.SLA Breached" endId="DST - SLA Breach Queue.Input"/>
            <path startId="CSPL - Route by Segment and Risk.Medium Value" endId="DST - fact_orders_enriched.Input"/>
            <path startId="CSPL - Route by Segment and Risk.Default Output" endId="DST - fact_orders_enriched.Input"/>
            <path startId="MCT - Duplicate High Value for Audit.To Fact Table" endId="DST - fact_orders_enriched.Input"/>
            <path startId="MCT - Duplicate High Value for Audit.To Audit Table" endId="DST - audit_high_value_orders.Input"/>
            <path startId="LKP - Customer Dimension.No Match Output" endId="DST - Error Log File.Input"/>
            <path startId="SRC - Extract New Orders.Error Output" endId="DST - Error Log File.Input"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- Task 3: Log results -->
    <DTS:Executable DTS:ObjectName="SQL - Log ETL Results"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="DW_Destination" ResultSetType="ResultSetType_SingleRow">
          <SqlStatement>EXEC audit.usp_LogETLRun @PackageName = 'ETL_Order_Enrichment', @RowsProcessed = ?</SqlStatement>
          <ResultBinding VariableName="User::RowsProcessed" ResultName="0"/>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <!-- PRECEDENCE CONSTRAINTS -->
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint DTS:From="SQL - Truncate Staging" DTS:To="DFT - Enrich and Route Orders" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="DFT - Enrich and Route Orders" DTS:To="SQL - Log ETL Results" DTS:Value="Completion"/>
  </DTS:PrecedenceConstraints>

  <!-- EVENT HANDLERS -->
  <DTS:EventHandlers>
    <DTS:EventHandler DTS:EventName="OnError">
      <DTS:Executables>
        <DTS:Executable DTS:ObjectName="Send Error Notification"
          DTS:ExecutableType="Microsoft.SendMailTask">
          <DTS:ObjectData>
            <SendMailTask ToLine="dw-alerts@company.com" Subject="SSIS FAILURE: ETL_Order_Enrichment"
              MessageSource="Package failed during execution"/>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:EventHandler>
  </DTS:EventHandlers>

</DTS:Executable>
