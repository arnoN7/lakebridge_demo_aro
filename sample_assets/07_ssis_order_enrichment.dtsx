<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts" DTS:refId="Package" DTS:ExecutableType="Microsoft.Package" DTS:ObjectName="ETL_Order_Enrichment">
  <DTS:Executables>
    <DTS:Executable DTS:refId="Package\DFT Orders" DTS:ExecutableType="Microsoft.Pipeline" DTS:ObjectName="DFT Orders">
      <DTS:ObjectData><pipeline><components><component refId="Package\DFT Orders\Src Orders Enriched" name="OLE DB Source" componentClassID="Microsoft.OLEDBSource"><properties><property name="AccessMode">2</property><property name="SqlCommand">SELECT d.OrderID, d.CustomerID, s.SegmentName, d.Quantity * d.UnitPrice AS LineAmount, CASE WHEN d.Quantity * d.UnitPrice &gt; 1000 THEN 'HighValue' ELSE 'Standard' END AS ValueBand FROM dbo.SalesOrderDetail d LEFT JOIN dbo.CustomerSegment s ON s.CustomerID = d.CustomerID</property></properties><outputs><output refId="Package\DFT Orders\Src Orders Enriched.Outputs[out]" name="OLE DB Source Output"><outputColumns><outputColumn refId="Package\DFT Orders\Src Orders Enriched.Outputs[out].Columns[OrderID]" name="OrderID"/><outputColumn refId="Package\DFT Orders\Src Orders Enriched.Outputs[out].Columns[CustomerID]" name="CustomerID"/><outputColumn refId="Package\DFT Orders\Src Orders Enriched.Outputs[out].Columns[SegmentName]" name="SegmentName"/><outputColumn refId="Package\DFT Orders\Src Orders Enriched.Outputs[out].Columns[LineAmount]" name="LineAmount"/><outputColumn refId="Package\DFT Orders\Src Orders Enriched.Outputs[out].Columns[ValueBand]" name="ValueBand"/></outputColumns></output></outputs></component><component refId="Package\DFT Orders\Dst fact_orders" name="OLE DB Destination" componentClassID="Microsoft.OLEDBDestination"><properties><property name="OpenRowset">[dw].[fact_order_enriched]</property></properties><inputs><input refId="Package\DFT Orders\Dst fact_orders.Inputs[in]" name="OLE DB Destination Input"><inputColumns/></input></inputs></component></components><paths><path refId="Package\DFT Orders.Paths[src2dst]" name="src2dst" startId="Package\DFT Orders\Src Orders Enriched.Outputs[out]" endId="Package\DFT Orders\Dst fact_orders.Inputs[in]"/></paths></pipeline></DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Audit" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Audit Row Count">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="INSERT INTO control.load_audit (package_name, loaded_at) SELECT 'ETL_Order_Enrichment', GETDATE();" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
