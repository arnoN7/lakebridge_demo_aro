<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts" DTS:refId="Package" DTS:ExecutableType="Microsoft.Package" DTS:ObjectName="ETL_Daily_Batch">
  <DTS:Executables>
    <DTS:Executable DTS:refId="Package\Fetch File" DTS:ExecutableType="Microsoft.FtpTask" DTS:ObjectName="Fetch Daily File">
      <DTS:ObjectData/>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Truncate Staging" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Truncate Staging">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="TRUNCATE TABLE staging.sales;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\DFT Stage Sales" DTS:ExecutableType="Microsoft.Pipeline" DTS:ObjectName="DFT Stage Sales">
      <DTS:ObjectData><pipeline><components><component refId="Package\DFT Stage Sales\Src Sales" name="OLE DB Source" componentClassID="Microsoft.OLEDBSource"><properties><property name="AccessMode">2</property><property name="SqlCommand">SELECT SalesID, ProductID, Amount, SaleDate FROM dbo.Sales WHERE SaleDate = CAST(GETDATE() AS DATE)</property></properties><outputs><output refId="Package\DFT Stage Sales\Src Sales.Outputs[out]" name="OLE DB Source Output"><outputColumns><outputColumn refId="Package\DFT Stage Sales\Src Sales.Outputs[out].Columns[SalesID]" name="SalesID"/><outputColumn refId="Package\DFT Stage Sales\Src Sales.Outputs[out].Columns[ProductID]" name="ProductID"/><outputColumn refId="Package\DFT Stage Sales\Src Sales.Outputs[out].Columns[Amount]" name="Amount"/><outputColumn refId="Package\DFT Stage Sales\Src Sales.Outputs[out].Columns[SaleDate]" name="SaleDate"/></outputColumns></output></outputs></component><component refId="Package\DFT Stage Sales\Dst stage_sales" name="OLE DB Destination" componentClassID="Microsoft.OLEDBDestination"><properties><property name="OpenRowset">[staging].[sales]</property></properties><inputs><input refId="Package\DFT Stage Sales\Dst stage_sales.Inputs[in]" name="OLE DB Destination Input"><inputColumns/></input></inputs></component></components><paths><path refId="Package\DFT Stage Sales.Paths[src2dst]" name="src2dst" startId="Package\DFT Stage Sales\Src Sales.Outputs[out]" endId="Package\DFT Stage Sales\Dst stage_sales.Inputs[in]"/></paths></pipeline></DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Load Fact" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Load Fact">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="INSERT INTO dw.fact_sales (ProductID, Amount, SaleDate) SELECT ProductID, SUM(Amount), SaleDate FROM staging.sales GROUP BY ProductID, SaleDate;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Update Control" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Update Control Table">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="UPDATE control.batch SET last_run = GETDATE(), rows_loaded = (SELECT COUNT(*) FROM staging.sales) WHERE batch_name = 'DailySales';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Notify" DTS:ExecutableType="Microsoft.SendMailTask" DTS:ObjectName="Notify On Complete">
      <DTS:ObjectData/>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
