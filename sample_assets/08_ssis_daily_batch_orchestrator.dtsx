<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:ObjectName="ETL_Daily_Batch_Orchestrator"
  DTS:Description="Master orchestration package: iterates over source systems, loads each in parallel sequences with retry logic and checkpoint support"
  DTS:CreatorName="DOMAIN\etl_admin"
  DTS:DTSID="{B2C3D4E5-F6A7-8901-BCDE-F23456789012}"
  DTS:ForceExecutionResult="0"
  DTS:CheckpointUsage="2"
  DTS:CheckpointFileName="\\fileserver\checkpoints\daily_batch.dtscp">

  <!-- CONNECTION MANAGERS -->
  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:ObjectName="ConfigDB"
      DTS:DTSID="{44444444-4444-4444-4444-444444444444}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLCONFIG01;Initial Catalog=ETL_Config;Provider=SQLNCLI11.1;Integrated Security=SSPI;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="StagingDB"
      DTS:DTSID="{55555555-5555-5555-5555-555555555555}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLSTAGE01;Initial Catalog=Staging;Provider=SQLNCLI11.1;Integrated Security=SSPI;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="WarehouseDB"
      DTS:DTSID="{66666666-6666-6666-6666-666666666666}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLDW01;Initial Catalog=DataWarehouse;Provider=SQLNCLI11.1;Integrated Security=SSPI;"
          DTS:Expression="@[User::DWConnectionString]"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="SMTP_Alerts"
      DTS:DTSID="{77777777-7777-7777-7777-777777777777}"
      DTS:CreationName="SMTP">
      <DTS:ObjectData>
        <DTS:ConnectionManager SmtpServer="smtp.company.com"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <!-- VARIABLES -->
  <DTS:Variables>
    <DTS:Variable DTS:ObjectName="BatchID" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="BatchDate" DTS:DataType="7" DTS:Namespace="User"
      DTS:Expression="(DT_DBTIMESTAMP)(DT_DBDATE)GETDATE()"/>
    <DTS:Variable DTS:ObjectName="CurrentSourceSystem" DTS:DataType="8" DTS:Namespace="User"/>
    <DTS:Variable DTS:ObjectName="CurrentTableName" DTS:DataType="8" DTS:Namespace="User"/>
    <DTS:Variable DTS:ObjectName="SourceSystemList" DTS:DataType="13" DTS:Namespace="User"/>
    <DTS:Variable DTS:ObjectName="TableList" DTS:DataType="13" DTS:Namespace="User"/>
    <DTS:Variable DTS:ObjectName="RetryCount" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="MaxRetries" DTS:DataType="3" DTS:Namespace="User">3</DTS:Variable>
    <DTS:Variable DTS:ObjectName="DWConnectionString" DTS:DataType="8" DTS:Namespace="User"
      DTS:Expression="&quot;Data Source=SQLDW01;Initial Catalog=DataWarehouse_&quot; + @[User::CurrentSourceSystem] + &quot;;Provider=SQLNCLI11.1;Integrated Security=SSPI;&quot;"/>
    <DTS:Variable DTS:ObjectName="TotalRowsLoaded" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="FailedSystems" DTS:DataType="8" DTS:Namespace="User"/>
    <DTS:Variable DTS:ObjectName="EmailBody" DTS:DataType="8" DTS:Namespace="User"
      DTS:Expression="&quot;Batch &quot; + (DT_WSTR,10)@[User::BatchID] + &quot; completed at &quot; + (DT_WSTR,30)GETDATE() + &quot;. Rows loaded: &quot; + (DT_WSTR,10)@[User::TotalRowsLoaded]"/>
  </DTS:Variables>

  <!-- CONTROL FLOW -->
  <DTS:Executables>

    <!-- ══════ Task 1: Initialize Batch ══════ -->
    <DTS:Executable DTS:ObjectName="SQL - Initialize Batch"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="ConfigDB" ResultSetType="ResultSetType_SingleRow">
          <SqlStatement>EXEC etl.usp_InitializeBatch @BatchDate = ?, @BatchID = ? OUTPUT</SqlStatement>
          <ParameterBinding VariableName="User::BatchDate" Direction="Input" DataType="DB_DBTIMESTAMP" ParameterName="0"/>
          <ParameterBinding VariableName="User::BatchID" Direction="Output" DataType="DB_I4" ParameterName="1"/>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 2: Get Source Systems to Process ══════ -->
    <DTS:Executable DTS:ObjectName="SQL - Get Active Source Systems"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="ConfigDB" ResultSetType="ResultSetType_Rowset">
          <SqlStatement>SELECT SystemName, SystemPriority, ConnectionString FROM etl.ActiveSourceSystems WHERE IsEnabled = 1 AND NextRunDate &lt;= GETDATE() ORDER BY SystemPriority</SqlStatement>
          <ResultBinding VariableName="User::SourceSystemList" ResultName="0"/>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 3: ForEach Loop — Iterate Source Systems ══════ -->
    <DTS:Executable DTS:ObjectName="FELC - Process Each Source System"
      DTS:ExecutableType="Microsoft.ForEachLoop">
      <DTS:ForEachEnumerator DTS:CreationName="Microsoft.ForEachADOEnumerator">
        <DTS:ObjectData>
          <FEAEM Variable="User::SourceSystemList" EnumType="EnumerateRowsInFirstTable"/>
        </DTS:ObjectData>
      </DTS:ForEachEnumerator>
      <DTS:VariableMappings>
        <DTS:VariableMapping VariableName="User::CurrentSourceSystem" ValueIndex="0"/>
      </DTS:VariableMappings>

      <DTS:Executables>

        <!-- ─── Sequence Container: Extract from Source ─── -->
        <DTS:Executable DTS:ObjectName="SEQ - Extract Phase"
          DTS:ExecutableType="Microsoft.SequenceContainer"
          DTS:TransactionOption="Required">
          <DTS:Executables>

            <!-- Get table list for this source -->
            <DTS:Executable DTS:ObjectName="SQL - Get Tables for Source"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask">
              <DTS:ObjectData>
                <SqlTaskData ConnectionName="ConfigDB" ResultSetType="ResultSetType_Rowset">
                  <SqlStatement>SELECT TableName, ExtractQuery, WatermarkColumn, LastWatermark FROM etl.SourceTables WHERE SystemName = ? AND IsActive = 1</SqlStatement>
                  <ParameterBinding VariableName="User::CurrentSourceSystem" Direction="Input" DataType="DB_WSTR" ParameterName="0"/>
                  <ResultBinding VariableName="User::TableList" ResultName="0"/>
                </SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>

            <!-- Nested ForEach: iterate tables -->
            <DTS:Executable DTS:ObjectName="FELC - Extract Each Table"
              DTS:ExecutableType="Microsoft.ForEachLoop">
              <DTS:ForEachEnumerator DTS:CreationName="Microsoft.ForEachADOEnumerator">
                <DTS:ObjectData>
                  <FEAEM Variable="User::TableList" EnumType="EnumerateRowsInFirstTable"/>
                </DTS:ObjectData>
              </DTS:ForEachEnumerator>
              <DTS:VariableMappings>
                <DTS:VariableMapping VariableName="User::CurrentTableName" ValueIndex="0"/>
              </DTS:VariableMappings>

              <DTS:Executables>
                <DTS:Executable DTS:ObjectName="DFT - Extract to Staging"
                  DTS:ExecutableType="Microsoft.Pipeline">
                  <DTS:ObjectData>
                    <pipeline>
                      <components>
                        <component componentClassID="Microsoft.OLEDBSource" name="SRC - Dynamic Source">
                          <properties>
                            <property name="SqlCommand" DTS:Expression="@[User::CurrentTableName]">SELECT * FROM dbo.placeholder WHERE ModifiedDate &gt; ?</property>
                            <property name="ParameterMapping">@[User::LastWatermark]:Input:0:DB_DBTIMESTAMP</property>
                          </properties>
                        </component>
                        <component componentClassID="Microsoft.OLEDBDestination" name="DST - Staging Table">
                          <properties>
                            <property name="OpenRowset" DTS:Expression="&quot;[staging].[&quot; + @[User::CurrentSourceSystem] + &quot;_&quot; + @[User::CurrentTableName] + &quot;]&quot;">[staging].[placeholder]</property>
                            <property name="FastLoadOptions">TABLOCK,ROWS_PER_BATCH=50000</property>
                          </properties>
                        </component>
                      </components>
                    </pipeline>
                  </DTS:ObjectData>
                </DTS:Executable>
              </DTS:Executables>
            </DTS:Executable>

          </DTS:Executables>
        </DTS:Executable>

        <!-- ─── Sequence Container: Transform + Load to DW ─── -->
        <DTS:Executable DTS:ObjectName="SEQ - Transform and Load Phase"
          DTS:ExecutableType="Microsoft.SequenceContainer"
          DTS:TransactionOption="Required">
          <DTS:Executables>

            <DTS:Executable DTS:ObjectName="SQL - Run Transformations"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask">
              <DTS:ObjectData>
                <SqlTaskData ConnectionName="StagingDB">
                  <SqlStatement>EXEC staging.usp_RunTransformations @SourceSystem = ?, @BatchID = ?</SqlStatement>
                  <ParameterBinding VariableName="User::CurrentSourceSystem" Direction="Input" DataType="DB_WSTR" ParameterName="0"/>
                  <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="1"/>
                </SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>

            <DTS:Executable DTS:ObjectName="SQL - Load Dimensions"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask">
              <DTS:ObjectData>
                <SqlTaskData ConnectionName="WarehouseDB">
                  <SqlStatement>EXEC dw.usp_LoadDimensions @SourceSystem = ?, @BatchID = ?</SqlStatement>
                  <ParameterBinding VariableName="User::CurrentSourceSystem" Direction="Input" DataType="DB_WSTR" ParameterName="0"/>
                  <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="1"/>
                </SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>

            <DTS:Executable DTS:ObjectName="SQL - Load Facts"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask">
              <DTS:ObjectData>
                <SqlTaskData ConnectionName="WarehouseDB">
                  <SqlStatement>EXEC dw.usp_LoadFacts @SourceSystem = ?, @BatchID = ?</SqlStatement>
                  <ParameterBinding VariableName="User::CurrentSourceSystem" Direction="Input" DataType="DB_WSTR" ParameterName="0"/>
                  <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="1"/>
                </SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>

          </DTS:Executables>
        </DTS:Executable>

        <!-- ─── Update watermarks after success ─── -->
        <DTS:Executable DTS:ObjectName="SQL - Update Watermarks"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask">
          <DTS:ObjectData>
            <SqlTaskData ConnectionName="ConfigDB">
              <SqlStatement>EXEC etl.usp_UpdateWatermarks @SystemName = ?, @BatchID = ?</SqlStatement>
              <ParameterBinding VariableName="User::CurrentSourceSystem" Direction="Input" DataType="DB_WSTR" ParameterName="0"/>
              <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="1"/>
            </SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>

      </DTS:Executables>

      <!-- Precedence within the loop -->
      <DTS:PrecedenceConstraints>
        <DTS:PrecedenceConstraint DTS:From="SEQ - Extract Phase" DTS:To="SEQ - Transform and Load Phase" DTS:Value="Success"/>
        <DTS:PrecedenceConstraint DTS:From="SEQ - Transform and Load Phase" DTS:To="SQL - Update Watermarks" DTS:Value="Success"/>
      </DTS:PrecedenceConstraints>
    </DTS:Executable>

    <!-- ══════ Task 4: Finalize Batch ══════ -->
    <DTS:Executable DTS:ObjectName="SQL - Finalize Batch"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="ConfigDB">
          <SqlStatement>EXEC etl.usp_FinalizeBatch @BatchID = ?, @Status = 'SUCCESS', @RowsLoaded = ?</SqlStatement>
          <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="0"/>
          <ParameterBinding VariableName="User::TotalRowsLoaded" Direction="Input" DataType="DB_I4" ParameterName="1"/>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 5: Send Completion Email ══════ -->
    <DTS:Executable DTS:ObjectName="Send Completion Email"
      DTS:ExecutableType="Microsoft.SendMailTask">
      <DTS:ObjectData>
        <SendMailTask ToLine="data-team@company.com" Subject="Daily Batch Complete"
          MessageSourceType="Variable" MessageSource="User::EmailBody"/>
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <!-- TOP-LEVEL PRECEDENCE CONSTRAINTS -->
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint DTS:From="SQL - Initialize Batch" DTS:To="SQL - Get Active Source Systems" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="SQL - Get Active Source Systems" DTS:To="FELC - Process Each Source System" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="FELC - Process Each Source System" DTS:To="SQL - Finalize Batch" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="SQL - Finalize Batch" DTS:To="Send Completion Email" DTS:Value="Success"/>
    <!-- On failure of the loop, still finalize but with FAILURE status -->
    <DTS:PrecedenceConstraint DTS:From="FELC - Process Each Source System" DTS:To="SQL - Finalize Batch" DTS:Value="Failure"
      DTS:Expression="TRUE" DTS:EvalOp="Expression"/>
  </DTS:PrecedenceConstraints>

  <!-- EVENT HANDLERS -->
  <DTS:EventHandlers>
    <DTS:EventHandler DTS:EventName="OnError">
      <DTS:Executables>
        <DTS:Executable DTS:ObjectName="SQL - Log Error"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask">
          <DTS:ObjectData>
            <SqlTaskData ConnectionName="ConfigDB">
              <SqlStatement>EXEC etl.usp_LogError @BatchID = ?, @SourceSystem = ?, @ErrorMessage = ?</SqlStatement>
              <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="0"/>
              <ParameterBinding VariableName="User::CurrentSourceSystem" Direction="Input" DataType="DB_WSTR" ParameterName="1"/>
              <ParameterBinding VariableName="System::ErrorDescription" Direction="Input" DataType="DB_WSTR" ParameterName="2"/>
            </SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:EventHandler>
    <DTS:EventHandler DTS:EventName="OnPreExecute">
      <DTS:Executables>
        <DTS:Executable DTS:ObjectName="SQL - Log Task Start"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask">
          <DTS:ObjectData>
            <SqlTaskData ConnectionName="ConfigDB">
              <SqlStatement>EXEC etl.usp_LogTaskExecution @BatchID = ?, @TaskName = ?, @Status = 'STARTED'</SqlStatement>
              <ParameterBinding VariableName="User::BatchID" Direction="Input" DataType="DB_I4" ParameterName="0"/>
              <ParameterBinding VariableName="System::TaskName" Direction="Input" DataType="DB_WSTR" ParameterName="1"/>
            </SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:EventHandler>
  </DTS:EventHandlers>

</DTS:Executable>
