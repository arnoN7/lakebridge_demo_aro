<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts" DTS:refId="Package" DTS:ExecutableType="Microsoft.Package" DTS:ObjectName="ETL_Product_SCD2">
  <DTS:Executables>
    <DTS:Executable DTS:refId="Package\Expire Old" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Expire Changed Rows">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="UPDATE dw.dim_product SET IsCurrent = 0, EndDate = GETDATE() WHERE IsCurrent = 1 AND ProductID IN (SELECT p.ProductID FROM dbo.Product p JOIN dw.dim_product d ON d.ProductID = p.ProductID AND d.IsCurrent = 1 WHERE d.ListPrice &lt;&gt; p.ListPrice);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\DFT Product" DTS:ExecutableType="Microsoft.Pipeline" DTS:ObjectName="DFT Product">
      <DTS:ObjectData><pipeline><components><component refId="Package\DFT Product\Src Changed Products" name="OLE DB Source" componentClassID="Microsoft.OLEDBSource"><properties><property name="AccessMode">2</property><property name="SqlCommand">SELECT p.ProductID, p.ProductName, p.ListPrice, p.Category FROM dbo.Product p LEFT JOIN dw.dim_product d ON d.ProductID = p.ProductID AND d.IsCurrent = 1 WHERE d.ProductID IS NULL OR d.ListPrice &lt;&gt; p.ListPrice</property></properties><outputs><output refId="Package\DFT Product\Src Changed Products.Outputs[out]" name="OLE DB Source Output"><outputColumns><outputColumn refId="Package\DFT Product\Src Changed Products.Outputs[out].Columns[ProductID]" name="ProductID"/><outputColumn refId="Package\DFT Product\Src Changed Products.Outputs[out].Columns[ProductName]" name="ProductName"/><outputColumn refId="Package\DFT Product\Src Changed Products.Outputs[out].Columns[ListPrice]" name="ListPrice"/><outputColumn refId="Package\DFT Product\Src Changed Products.Outputs[out].Columns[Category]" name="Category"/></outputColumns></output></outputs></component><component refId="Package\DFT Product\Dst new_version" name="OLE DB Destination" componentClassID="Microsoft.OLEDBDestination"><properties><property name="OpenRowset">[dw].[dim_product]</property></properties><inputs><input refId="Package\DFT Product\Dst new_version.Inputs[in]" name="OLE DB Destination Input"><inputColumns/></input></inputs></component></components><paths><path refId="Package\DFT Product.Paths[src2dst]" name="src2dst" startId="Package\DFT Product\Src Changed Products.Outputs[out]" endId="Package\DFT Product\Dst new_version.Inputs[in]"/></paths></pipeline></DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
