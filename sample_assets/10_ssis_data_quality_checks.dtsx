<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:ObjectName="ETL_Data_Quality_Validation"
  DTS:Description="Multi-source data quality framework: validates referential integrity, business rules, statistical outliers, and data freshness using Script Components and Aggregates"
  DTS:CreatorName="DOMAIN\dq_team"
  DTS:DTSID="{D4E5F6A7-B8C9-0123-DEFA-456789012345}">

  <!-- CONNECTION MANAGERS -->
  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:ObjectName="WarehouseDB"
      DTS:DTSID="{99999999-9999-9999-9999-999999999901}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLDW01;Initial Catalog=DataWarehouse;Provider=SQLNCLI11.1;Integrated Security=SSPI;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="DQ_ResultsDB"
      DTS:DTSID="{99999999-9999-9999-9999-999999999902}"
      DTS:CreationName="OLEDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLQUALITY01;Initial Catalog=DataQuality;Provider=SQLNCLI11.1;Integrated Security=SSPI;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:ObjectName="DQ_Report_FlatFile"
      DTS:DTSID="{99999999-9999-9999-9999-999999999903}"
      DTS:CreationName="FLATFILE">
      <DTS:ObjectData>
        <DTS:ConnectionManager Format="Delimited" ColumnNamesInFirstDataRow="True"
          ConnectionString="\\reports\data_quality\dq_exceptions.csv"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <!-- VARIABLES -->
  <DTS:Variables>
    <DTS:Variable DTS:ObjectName="DQ_RunID" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="DQ_RunDate" DTS:DataType="7" DTS:Namespace="User"
      DTS:Expression="GETDATE()"/>
    <DTS:Variable DTS:ObjectName="TotalExceptions" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="CriticalExceptions" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="PassedChecks" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="FailedChecks" DTS:DataType="3" DTS:Namespace="User">0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="OverallScore" DTS:DataType="5" DTS:Namespace="User">0.0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="ThresholdPct" DTS:DataType="5" DTS:Namespace="User">95.0</DTS:Variable>
    <DTS:Variable DTS:ObjectName="StdDevMultiplier" DTS:DataType="5" DTS:Namespace="User">3.0</DTS:Variable>
  </DTS:Variables>

  <!-- CONTROL FLOW -->
  <DTS:Executables>

    <!-- ══════ Task 1: Initialize DQ Run ══════ -->
    <DTS:Executable DTS:ObjectName="SQL - Initialize DQ Run"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="DQ_ResultsDB" ResultSetType="ResultSetType_SingleRow">
          <SqlStatement>EXEC dq.usp_InitializeRun @RunDate = ?, @RunID = ? OUTPUT</SqlStatement>
          <ParameterBinding VariableName="User::DQ_RunDate" Direction="Input" DataType="DB_DBTIMESTAMP" ParameterName="0"/>
          <ParameterBinding VariableName="User::DQ_RunID" Direction="Output" DataType="DB_I4" ParameterName="1"/>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 2: Referential Integrity Checks ══════ -->
    <DTS:Executable DTS:ObjectName="DFT - Referential Integrity Checks"
      DTS:ExecutableType="Microsoft.Pipeline">
      <DTS:ObjectData>
        <pipeline>
          <components>

            <!-- SOURCE: Find orphaned foreign keys -->
            <component componentClassID="Microsoft.OLEDBSource" name="SRC - Orphaned FK Records">
              <properties>
                <property name="SqlCommand">
                  SELECT 'fact_sales.CustomerKey' AS CheckName, f.SalesKey AS RecordID,
                    'CRITICAL' AS Severity, 'Orphaned CustomerKey: ' + CAST(f.CustomerKey AS VARCHAR) AS Details
                  FROM dw.fact_sales f
                  LEFT JOIN dw.dim_customer c ON f.CustomerKey = c.CustomerKey
                  WHERE c.CustomerKey IS NULL AND f.LoadDate &gt;= DATEADD(DAY, -1, GETDATE())
                  UNION ALL
                  SELECT 'fact_sales.ProductKey', f.SalesKey,
                    'CRITICAL', 'Orphaned ProductKey: ' + CAST(f.ProductKey AS VARCHAR)
                  FROM dw.fact_sales f
                  LEFT JOIN dw.dim_product p ON f.ProductKey = p.ProductKey
                  WHERE p.ProductKey IS NULL AND f.LoadDate &gt;= DATEADD(DAY, -1, GETDATE())
                  UNION ALL
                  SELECT 'fact_sales.DateKey', f.SalesKey,
                    'WARNING', 'Missing DateKey: ' + CAST(f.DateKey AS VARCHAR)
                  FROM dw.fact_sales f
                  LEFT JOIN dw.dim_date d ON f.DateKey = d.DateKey
                  WHERE d.DateKey IS NULL AND f.LoadDate &gt;= DATEADD(DAY, -1, GETDATE())
                </property>
              </properties>
            </component>

            <!-- DATA CONVERSION: Normalize data types -->
            <component componentClassID="Microsoft.DataConvert" name="DC - Normalize Types">
              <properties>
                <property name="Conversions">
                  <conversion inputColumn="RecordID" outputColumn="RecordID_STR" dataType="DT_WSTR" length="50"/>
                  <conversion inputColumn="Details" outputColumn="Details_TRIMMED" dataType="DT_WSTR" length="500"/>
                </property>
              </properties>
            </component>

            <!-- SCRIPT COMPONENT: Apply complex validation rules -->
            <component componentClassID="Microsoft.ScriptComponent" name="SCR - Apply Business Rules"
              DTS:ScriptLanguage="Microsoft.VisualBasic">
              <properties>
                <property name="Script">
                  Public Overrides Sub Input0_ProcessInputRow(ByVal Row As Input0Buffer)
                    ' Apply severity escalation rules
                    If Row.Severity = "WARNING" And Row.CheckName.Contains("CustomerKey") Then
                      ' Escalate customer orphans to CRITICAL if count exceeds threshold
                      Row.Severity = "CRITICAL"
                      Row.Details = Row.Details + " [ESCALATED: customer orphan]"
                    End If
                    ' Add DQ metadata
                    Row.DQRunID = Variables.DQ_RunID
                    Row.DQTimestamp = DateTime.Now
                    Row.RuleName = "RI_" + Row.CheckName.Replace(".", "_")
                  End Sub
                </property>
                <property name="ReadOnlyVariables">User::DQ_RunID</property>
              </properties>
              <outputs>
                <output name="Script Output">
                  <outputColumns>
                    <outputColumn name="DQRunID" dataType="DT_I4"/>
                    <outputColumn name="DQTimestamp" dataType="DT_DBTIMESTAMP"/>
                    <outputColumn name="RuleName" dataType="DT_WSTR" length="100"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- ROW COUNT -->
            <component componentClassID="Microsoft.RowCount" name="RC - Count RI Exceptions">
              <properties>
                <property name="VariableName">User::TotalExceptions</property>
              </properties>
            </component>

            <!-- DESTINATION: Exception table -->
            <component componentClassID="Microsoft.OLEDBDestination" name="DST - DQ Exceptions">
              <properties>
                <property name="OpenRowset">[dq].[exceptions]</property>
                <property name="FastLoadOptions">TABLOCK</property>
              </properties>
            </component>

          </components>

          <paths>
            <path startId="SRC - Orphaned FK Records.Output" endId="DC - Normalize Types.Input"/>
            <path startId="DC - Normalize Types.Output" endId="SCR - Apply Business Rules.Input"/>
            <path startId="SCR - Apply Business Rules.Output" endId="RC - Count RI Exceptions.Input"/>
            <path startId="RC - Count RI Exceptions.Output" endId="DST - DQ Exceptions.Input"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 3: Statistical Outlier Detection ══════ -->
    <DTS:Executable DTS:ObjectName="DFT - Statistical Outlier Detection"
      DTS:ExecutableType="Microsoft.Pipeline">
      <DTS:ObjectData>
        <pipeline>
          <components>

            <!-- SOURCE: Daily aggregates for outlier detection -->
            <component componentClassID="Microsoft.OLEDBSource" name="SRC - Daily Sales Aggregates">
              <properties>
                <property name="SqlCommand">
                  SELECT
                    CAST(OrderDate AS DATE) AS SalesDate,
                    COUNT(*) AS OrderCount,
                    SUM(TotalAmount) AS DailyRevenue,
                    AVG(TotalAmount) AS AvgOrderValue,
                    STDEV(TotalAmount) AS StdDevOrderValue
                  FROM dw.fact_sales
                  WHERE OrderDate &gt;= DATEADD(DAY, -90, GETDATE())
                  GROUP BY CAST(OrderDate AS DATE)
                </property>
              </properties>
            </component>

            <!-- AGGREGATE: Compute baseline stats -->
            <component componentClassID="Microsoft.Aggregate" name="AGG - Compute Baseline Statistics">
              <properties>
                <property name="AggregationOperations">
                  <aggregation outputColumn="BaselineAvgRevenue" inputColumn="DailyRevenue" operation="Average"/>
                  <aggregation outputColumn="BaselineStdDev" inputColumn="DailyRevenue" operation="StdDev"/>
                  <aggregation outputColumn="BaselineMinRevenue" inputColumn="DailyRevenue" operation="Minimum"/>
                  <aggregation outputColumn="BaselineMaxRevenue" inputColumn="DailyRevenue" operation="Maximum"/>
                  <aggregation outputColumn="TotalDays" inputColumn="SalesDate" operation="CountDistinct"/>
                </property>
                <property name="KeyScale">Medium</property>
              </properties>
            </component>

            <!-- SCRIPT COMPONENT: Z-Score calculation and outlier flagging -->
            <component componentClassID="Microsoft.ScriptComponent" name="SCR - ZScore Outlier Detection"
              DTS:ScriptLanguage="Microsoft.CSharp">
              <properties>
                <property name="Script">
                  public override void Input0_ProcessInputRow(Input0Buffer Row)
                  {
                      double zScore = 0;
                      if (Row.StdDevOrderValue > 0)
                      {
                          zScore = Math.Abs((Row.DailyRevenue - Row.BaselineAvgRevenue) / Row.BaselineStdDev);
                      }
                      Row.ZScore = zScore;
                      Row.IsOutlier = zScore > (double)Variables.StdDevMultiplier;
                      Row.OutlierDirection = Row.DailyRevenue > Row.BaselineAvgRevenue ? "HIGH" : "LOW";

                      if (Row.IsOutlier)
                      {
                          Row.Severity = zScore > 4.0 ? "CRITICAL" : "WARNING";
                          Row.Details = String.Format("Revenue {0:C} on {1:d} (Z={2:F2}, baseline={3:C}+/-{4:C})",
                              Row.DailyRevenue, Row.SalesDate, zScore,
                              Row.BaselineAvgRevenue, Row.BaselineStdDev);
                      }
                  }
                </property>
                <property name="ReadOnlyVariables">User::StdDevMultiplier</property>
              </properties>
              <outputs>
                <output name="Outlier Output">
                  <outputColumns>
                    <outputColumn name="ZScore" dataType="DT_R8"/>
                    <outputColumn name="IsOutlier" dataType="DT_BOOL"/>
                    <outputColumn name="OutlierDirection" dataType="DT_WSTR" length="10"/>
                    <outputColumn name="Severity" dataType="DT_WSTR" length="20"/>
                    <outputColumn name="Details" dataType="DT_WSTR" length="500"/>
                  </outputColumns>
                </output>
              </outputs>
            </component>

            <!-- CONDITIONAL SPLIT: Route outliers vs normal -->
            <component componentClassID="Microsoft.ConditionalSplit" name="CSPL - Route Outliers">
              <outputs>
                <output name="Outliers" expression="IsOutlier == TRUE"/>
                <output name="Normal"/>
              </outputs>
            </component>

            <!-- ROW SAMPLING: Sample normal data for profiling -->
            <component componentClassID="Microsoft.RowSampling" name="RS - Sample Normal Data">
              <properties>
                <property name="SamplingValue">100</property>
                <property name="SamplingSeed">42</property>
              </properties>
            </component>

            <!-- DESTINATION: Outlier exceptions -->
            <component componentClassID="Microsoft.OLEDBDestination" name="DST - Outlier Exceptions">
              <properties>
                <property name="OpenRowset">[dq].[statistical_outliers]</property>
              </properties>
            </component>

            <!-- DESTINATION: Profiling sample -->
            <component componentClassID="Microsoft.OLEDBDestination" name="DST - Profile Sample">
              <properties>
                <property name="OpenRowset">[dq].[profiling_samples]</property>
              </properties>
            </component>

          </components>

          <paths>
            <path startId="SRC - Daily Sales Aggregates.Output" endId="AGG - Compute Baseline Statistics.Input"/>
            <path startId="AGG - Compute Baseline Statistics.Output" endId="SCR - ZScore Outlier Detection.Input"/>
            <path startId="SCR - ZScore Outlier Detection.Output" endId="CSPL - Route Outliers.Input"/>
            <path startId="CSPL - Route Outliers.Outliers" endId="DST - Outlier Exceptions.Input"/>
            <path startId="CSPL - Route Outliers.Normal" endId="RS - Sample Normal Data.Input"/>
            <path startId="RS - Sample Normal Data.Output" endId="DST - Profile Sample.Input"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 4: Data Freshness Check ══════ -->
    <DTS:Executable DTS:ObjectName="SQL - Check Data Freshness"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="WarehouseDB" ResultSetType="ResultSetType_Rowset">
          <SqlStatement>
            SELECT TableName, MAX(LoadDate) AS LastLoadDate,
              DATEDIFF(HOUR, MAX(LoadDate), GETDATE()) AS HoursSinceLoad,
              CASE WHEN DATEDIFF(HOUR, MAX(LoadDate), GETDATE()) &gt; 24 THEN 'STALE'
                   WHEN DATEDIFF(HOUR, MAX(LoadDate), GETDATE()) &gt; 6  THEN 'WARNING'
                   ELSE 'FRESH' END AS FreshnessStatus
            FROM (
              SELECT 'fact_sales' AS TableName, MAX(LoadDate) AS LoadDate FROM dw.fact_sales
              UNION ALL SELECT 'fact_inventory', MAX(LoadDate) FROM dw.fact_inventory
              UNION ALL SELECT 'dim_customer', MAX(LoadDate) FROM dw.dim_customer
              UNION ALL SELECT 'dim_product', MAX(LoadDate) FROM dw.dim_product
            ) t GROUP BY TableName
          </SqlStatement>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 5: Compute Overall DQ Score ══════ -->
    <DTS:Executable DTS:ObjectName="SQL - Compute DQ Score"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SqlTaskData ConnectionName="DQ_ResultsDB" ResultSetType="ResultSetType_SingleRow">
          <SqlStatement>
            EXEC dq.usp_ComputeOverallScore @RunID = ?, @Score = ? OUTPUT, @Passed = ? OUTPUT, @Failed = ? OUTPUT
          </SqlStatement>
          <ParameterBinding VariableName="User::DQ_RunID" Direction="Input" DataType="DB_I4" ParameterName="0"/>
          <ParameterBinding VariableName="User::OverallScore" Direction="Output" DataType="DB_R8" ParameterName="1"/>
          <ParameterBinding VariableName="User::PassedChecks" Direction="Output" DataType="DB_I4" ParameterName="2"/>
          <ParameterBinding VariableName="User::FailedChecks" Direction="Output" DataType="DB_I4" ParameterName="3"/>
        </SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 6: Conditional — Alert if below threshold ══════ -->
    <DTS:Executable DTS:ObjectName="Send DQ Alert"
      DTS:ExecutableType="Microsoft.SendMailTask">
      <DTS:ObjectData>
        <SendMailTask ToLine="data-quality@company.com; data-governance@company.com"
          Subject="DATA QUALITY ALERT: Score below threshold"
          MessageSourceType="Variable" MessageSource="User::EmailBody"/>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- ══════ Task 7: Export DQ Report ══════ -->
    <DTS:Executable DTS:ObjectName="DFT - Export DQ Report"
      DTS:ExecutableType="Microsoft.Pipeline">
      <DTS:ObjectData>
        <pipeline>
          <components>
            <component componentClassID="Microsoft.OLEDBSource" name="SRC - DQ Summary">
              <properties>
                <property name="SqlCommand">SELECT * FROM dq.vw_RunSummary WHERE RunID = ?</property>
                <property name="ParameterMapping">@[User::DQ_RunID]:Input:0:DB_I4</property>
              </properties>
            </component>
            <component componentClassID="Microsoft.FlatFileDestination" name="DST - CSV Report">
              <properties>
                <property name="ConnectionManager">{99999999-9999-9999-9999-999999999903}</property>
                <property name="Overwrite">true</property>
              </properties>
            </component>
          </components>
          <paths>
            <path startId="SRC - DQ Summary.Output" endId="DST - CSV Report.Input"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <!-- PRECEDENCE CONSTRAINTS -->
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint DTS:From="SQL - Initialize DQ Run" DTS:To="DFT - Referential Integrity Checks" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="SQL - Initialize DQ Run" DTS:To="DFT - Statistical Outlier Detection" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="SQL - Initialize DQ Run" DTS:To="SQL - Check Data Freshness" DTS:Value="Success"/>
    <DTS:PrecedenceConstraint DTS:From="DFT - Referential Integrity Checks" DTS:To="SQL - Compute DQ Score" DTS:Value="Completion"/>
    <DTS:PrecedenceConstraint DTS:From="DFT - Statistical Outlier Detection" DTS:To="SQL - Compute DQ Score" DTS:Value="Completion"/>
    <DTS:PrecedenceConstraint DTS:From="SQL - Check Data Freshness" DTS:To="SQL - Compute DQ Score" DTS:Value="Completion"/>
    <!-- Alert only fires when score is below threshold -->
    <DTS:PrecedenceConstraint DTS:From="SQL - Compute DQ Score" DTS:To="Send DQ Alert" DTS:Value="Success"
      DTS:Expression="@[User::OverallScore] &lt; @[User::ThresholdPct]" DTS:EvalOp="ExpressionAndConstraint"/>
    <DTS:PrecedenceConstraint DTS:From="SQL - Compute DQ Score" DTS:To="DFT - Export DQ Report" DTS:Value="Success"/>
  </DTS:PrecedenceConstraints>

  <!-- EVENT HANDLERS -->
  <DTS:EventHandlers>
    <DTS:EventHandler DTS:EventName="OnError">
      <DTS:Executables>
        <DTS:Executable DTS:ObjectName="SQL - Log DQ Error"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask">
          <DTS:ObjectData>
            <SqlTaskData ConnectionName="DQ_ResultsDB">
              <SqlStatement>EXEC dq.usp_LogError @RunID = ?, @TaskName = ?, @ErrorCode = ?, @ErrorDescription = ?</SqlStatement>
              <ParameterBinding VariableName="User::DQ_RunID" Direction="Input" DataType="DB_I4" ParameterName="0"/>
              <ParameterBinding VariableName="System::TaskName" Direction="Input" DataType="DB_WSTR" ParameterName="1"/>
              <ParameterBinding VariableName="System::ErrorCode" Direction="Input" DataType="DB_I4" ParameterName="2"/>
              <ParameterBinding VariableName="System::ErrorDescription" Direction="Input" DataType="DB_WSTR" ParameterName="3"/>
            </SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:EventHandler>
    <DTS:EventHandler DTS:EventName="OnPostExecute">
      <DTS:Executables>
        <DTS:Executable DTS:ObjectName="SQL - Log Task Completion"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask">
          <DTS:ObjectData>
            <SqlTaskData ConnectionName="DQ_ResultsDB">
              <SqlStatement>EXEC dq.usp_LogTaskComplete @RunID = ?, @TaskName = ?, @Duration = ?</SqlStatement>
              <ParameterBinding VariableName="User::DQ_RunID" Direction="Input" DataType="DB_I4" ParameterName="0"/>
              <ParameterBinding VariableName="System::TaskName" Direction="Input" DataType="DB_WSTR" ParameterName="1"/>
              <ParameterBinding VariableName="System::TaskTransactionOption" Direction="Input" DataType="DB_I4" ParameterName="2"/>
            </SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:EventHandler>
  </DTS:EventHandlers>

</DTS:Executable>
