<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts" DTS:refId="Package" DTS:ExecutableType="Microsoft.Package" DTS:ObjectName="ETL_Data_Quality">
  <DTS:Executables>
    <DTS:Executable DTS:refId="Package\Null Check" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Null Check">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="INSERT INTO dq.results (rule, failed_rows) SELECT 'null_email', COUNT(*) FROM staging.raw_orders WHERE CustomerEmail IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Range Check" DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:ObjectName="Range Check">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData SQLTask:SqlStatementSource="INSERT INTO dq.results (rule, failed_rows) SELECT 'negative_amount', COUNT(*) FROM staging.raw_orders WHERE OrderAmount &lt; 0;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\Validate API" DTS:ExecutableType="Microsoft.WebServiceTask" DTS:ObjectName="Validate via Web Service">
      <DTS:ObjectData/>
    </DTS:Executable>
    <DTS:Executable DTS:refId="Package\DFT DQ" DTS:ExecutableType="Microsoft.Pipeline" DTS:ObjectName="DFT DQ">
      <DTS:ObjectData><pipeline><components><component refId="Package\DFT DQ\Src Invalid Rows" name="OLE DB Source" componentClassID="Microsoft.OLEDBSource"><properties><property name="AccessMode">2</property><property name="SqlCommand">SELECT RecordID, CustomerEmail, OrderAmount, CASE WHEN CustomerEmail IS NULL THEN 'null_email' WHEN OrderAmount &lt; 0 THEN 'negative_amount' END AS dq_reason FROM staging.raw_orders WHERE CustomerEmail IS NULL OR OrderAmount &lt; 0</property></properties><outputs><output refId="Package\DFT DQ\Src Invalid Rows.Outputs[out]" name="OLE DB Source Output"><outputColumns><outputColumn refId="Package\DFT DQ\Src Invalid Rows.Outputs[out].Columns[RecordID]" name="RecordID"/><outputColumn refId="Package\DFT DQ\Src Invalid Rows.Outputs[out].Columns[CustomerEmail]" name="CustomerEmail"/><outputColumn refId="Package\DFT DQ\Src Invalid Rows.Outputs[out].Columns[OrderAmount]" name="OrderAmount"/><outputColumn refId="Package\DFT DQ\Src Invalid Rows.Outputs[out].Columns[dq_reason]" name="dq_reason"/></outputColumns></output></outputs></component><component refId="Package\DFT DQ\Dst quarantine" name="OLE DB Destination" componentClassID="Microsoft.OLEDBDestination"><properties><property name="OpenRowset">[dq].[quarantine]</property></properties><inputs><input refId="Package\DFT DQ\Dst quarantine.Inputs[in]" name="OLE DB Destination Input"><inputColumns/></input></inputs></component></components><paths><path refId="Package\DFT DQ.Paths[src2dst]" name="src2dst" startId="Package\DFT DQ\Src Invalid Rows.Outputs[out]" endId="Package\DFT DQ\Dst quarantine.Inputs[in]"/></paths></pipeline></DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
